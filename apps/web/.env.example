# Directus connection for the Next.js site.
#
# The app runs WITHOUT any of these set — it falls back to bundled demo data
# (data/devices.ts, a mirror of the repo-root data/devices.json). Set them to
# read live content from a Directus instance.

# Server-side base URL (preferred by server components; NOT exposed to the browser).
# Local dev example:  http://localhost:8055
# Production example: https://api.your-domain.ru
DIRECTUS_URL=http://localhost:8055

# Browser-visible base URL. Only needed if client-side code must call Directus
# directly (e.g. for asset URLs). Safe to mirror DIRECTUS_URL.
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055

# Optional read token for a least-privilege public/service account.
# Leave empty for an anonymous-read Directus role. NEVER use the admin token.
# DIRECTUS_TOKEN=replace-with-public-read-token

# Optional create-only token for public lead intake.
# It should allow CREATE on the Directus `leads` collection only.
# If omitted, /api/leads stores submissions in LEADS_LOG_PATH instead.
# DIRECTUS_LEADS_TOKEN=replace-with-lead-intake-token

# Private fallback log for form submissions when DIRECTUS_LEADS_TOKEN is absent
# or Directus rejects the request. Keep it outside public/static directories.
LEADS_LOG_PATH=var/leads.jsonl
