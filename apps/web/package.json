{
  "name": "@vtoroy/web",
  "version": "0.1.0",
  "private": true,
  "description": "Production Next.js public site for ISVOI, backed by Directus.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components lib data --ext .ts,.tsx",
    "tailwind:audit": "eslint app components lib data --ext .ts,.tsx --no-error-on-unmatched-pattern",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore",
    "format:write": "prettier --write . --ignore-path ../../.prettierignore",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vtoroy/shared": "*",
    "clsx": "^2.1.1",
    "htmlparser2": "8.0.2",
    "next": "^15.5.19",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sanitize-html": "2.17.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/sanitize-html": "2.16.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.19",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "postcss": "^8.4.38",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.0"
  }
}
