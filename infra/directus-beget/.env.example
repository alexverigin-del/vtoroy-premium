# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
#   cp .env.example .env
#
# Generate strong random secrets, e.g.:
#   openssl rand -hex 32

# --- Directus ---
# Long random string used to sign tokens. REQUIRED. Keep secret.
SECRET=replace-with-openssl-rand-hex-32

# First-run bootstrap admin (Directus Studio login). Change password after login.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-password

# Public URL Directus advertises (matches the api/admin nginx server_name).
PUBLIC_URL=https://api.your-domain.ru

# Realtime / WebSockets ("true" | "false").
WEBSOCKETS_ENABLED=true

# Allowed browser origin(s) for the public Next.js site (CORS).
CORS_ORIGIN=https://your-domain.ru

# --- PostgreSQL ---
DB_DATABASE=vtoroy
DB_USER=vtoroy
DB_PASSWORD=replace-with-strong-db-password

# --- Optional Redis cache ---
# Set CACHE_ENABLED=false and remove the `cache` service if you don't want Redis.
CACHE_ENABLED=true
