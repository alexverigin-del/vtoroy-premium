# nginx vhost for the PUBLIC site (Next.js).
#
# Replace your-domain.ru with the real domain. TLS certs are assumed to be
# issued by certbot/Let's Encrypt; adjust paths as needed. This is an EXAMPLE —
# review before using in production.

server {
    listen 80;
    server_name your-domain.ru www.your-domain.ru;
    # Redirect all HTTP to HTTPS.
    return 301 https://$host$request_uri;
}

limit_req_zone $binary_remote_addr zone=isvoi_lead_intake:10m rate=6r/m;

server {
    listen 443 ssl http2;
    server_name your-domain.ru www.your-domain.ru;

    ssl_certificate     /etc/letsencrypt/live/your-domain.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/your-domain.ru/privkey.pem;

    # Legacy/reference media. Prefer Directus Files for new product/content
    # images; keep this alias only while old bundled assets are still referenced.
    location /assets/ {
        alias /var/www/vtoroy-premium-landing/assets/;
        expires 30d;
        add_header Cache-Control "public, max-age=2592000, immutable";
    }

    # The Next.js app (`next start`) listening on localhost:3000.
    location = /lead-intake {
        limit_req zone=isvoi_lead_intake burst=4 nodelay;
        limit_req_status 429;

        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Directus Live Preview uses a one-purpose secret in the query string, as
    # required by the Next.js Draft Mode handshake. Keep it out of access logs.
    location = /api/draft/blog {
        access_log off;

        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Do not serve the repository root as static HTML in production. Legacy
    # `.html` URLs are handled by Next.js redirects in apps/web/next.config.mjs.
}
