{
  "name": "vtoroy-premium",
  "version": "0.1.0",
  "private": true,
  "description": "ISVOI — Next.js + Directus public site and catalog operations toolkit.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web:dev": "npm run dev --workspace @vtoroy/web",
    "web:build": "npm run build --workspace @vtoroy/web",
    "web:start": "npm run start --workspace @vtoroy/web",
    "text:audit": "python scripts/audit_text_encoding.py",
    "legacy:audit": "python scripts/audit_legacy_html.py",
    "directus:seed": "python scripts/seed_directus.py",
    "directus:import:xlsx": "python scripts/import_devices_from_excel.py",
    "directus:catalog:batch": "bash scripts/run_catalog_import_batch.sh",
    "directus:catalog:operator": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/operator_catalog_import.ps1",
    "directus:catalog:template": "python scripts/create_catalog_import_template.py",
    "directus:media": "node scripts/import_device_media.mjs",
    "directus:site-assets": "node scripts/import_site_assets.mjs",
    "directus:normalize-images": "node scripts/normalize_directus_image_refs.mjs",
    "directus:normalize-device-images-sql": "node scripts/normalize_directus_device_image_refs_sql.mjs",
    "directus:schema:snapshot": "node scripts/export_directus_schema_snapshot.mjs",
    "directus:audit-schema": "node scripts/audit_directus_schema_sql.mjs",
    "directus:audit-images": "node scripts/audit_directus_image_refs_sql.mjs",
    "directus:audit-catalog": "node scripts/audit_directus_catalog_sql.mjs",
    "directus:setup:file-folders": "node scripts/setup_directus_file_folders_sql.mjs",
    "directus:setup:files-cleanup": "node scripts/setup_directus_files_cleanup_sql.mjs",
    "directus:setup:site-content": "node scripts/setup_directus_site_content_sql.mjs",
    "directus:setup:site-pages-workflow": "node scripts/setup_directus_site_pages_workflow_sql.mjs",
    "directus:setup:catalog-studio": "node scripts/setup_directus_catalog_studio_sql.mjs",
    "directus:setup:global-content": "node scripts/setup_directus_global_content_sql.mjs",
    "directus:setup:public-permissions": "node scripts/setup_directus_public_permissions_sql.mjs",
    "directus:setup:catalog-import-button": "node scripts/setup_directus_catalog_import_button_sql.mjs",
    "directus:setup:catalog-import-operator-screen": "node scripts/setup_directus_catalog_import_operator_screen_sql.mjs",
    "directus:setup:catalog": "node scripts/setup_directus_catalog_sql.mjs",
    "directus:setup:catalog-structured-data": "node scripts/setup_directus_catalog_structured_data_sql.mjs",
    "directus:setup:faq-editor": "node scripts/setup_directus_faq_editor_sql.mjs",
    "directus:setup:technical-permissions": "node scripts/setup_directus_technical_permissions_sql.mjs",
    "directus:setup:admin-guardrails": "node scripts/setup_directus_admin_guardrails_sql.mjs",
    "directus:seed:marketing-pages": "node scripts/seed_marketing_pages_sql.mjs",
    "directus:seed:faq": "node scripts/seed_directus_faq_sql.mjs",
    "directus:normalize-urls": "node scripts/normalize_directus_site_urls_sql.mjs",
    "directus:setup:leads": "node scripts/setup_directus_leads_sql.mjs",
    "directus:setup:editor": "node scripts/setup_directus_editor_sql.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
