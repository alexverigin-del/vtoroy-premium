# Copy to `.env` and fill in real values. NEVER commit `.env`.
#   cp .env.example .env
#
# Used by the back-office Python jobs in this folder:
#   - seed_directus.py            (catalog seed/upsert)
#   - import_device_media.mjs     (upload/link device photos to Directus Files)
#   - import_devices_from_excel.py (stock spreadsheet -> catalog)
#   - notify_telegram.py          (lead/report alerts)
#   - optimize_images.py          (raw photos -> WebP; uses CLI args, no env)

# --- Directus API ---
# Base URL of the Directus instance the jobs talk to.
#   Local:      http://localhost:8055
#   Production: https://api.your-domain.ru
DIRECTUS_URL=https://api.your-domain.ru
# Static token for an Editor-role service account (NOT the admin token).
# Create it in Studio: the Editor user -> Token -> generate static token.
DIRECTUS_TOKEN=replace-with-service-account-token

# --- Telegram notifications (notify_telegram.py) ---
# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=replace-with-botfather-token
# Chat/channel ID the alerts are sent to (e.g. from @userinfobot).
TELEGRAM_CHAT_ID=replace-with-chat-id

# --- Storage paths (informational) ---
# seed_directus.py reads the catalog JSON; default is data/devices.json at the
# repo root (relative to the script). Override per run with --file /path.json.
# import_device_media.mjs reads the same catalog JSON and uploads image paths
# from apps/web/public by default:
#   node scripts/import_device_media.mjs --file data/devices.json --assets-root apps/web/public
# Use --dry-run first, and --replace only when intentionally overwriting
# existing Directus Files/device_images links.
# import_devices_from_excel.py can update device rows and media from one .xlsx:
#   python scripts/import_devices_from_excel.py --file stock.xlsx --assets-root ./optimized --import-batch 2026-06-stock --dry-run
#   python scripts/import_devices_from_excel.py --file stock.xlsx --assets-root ./optimized --import-batch 2026-06-stock
# Image columns are image_card, image_main, image_screen, image_body,
# image_defect, image_other plus optional image_{role}_alt/label columns.
# import_site_assets.mjs uploads non-product site images and links homepage
# sections to Directus Files:
#   node scripts/import_site_assets.mjs --dry-run
#   node scripts/import_site_assets.mjs
# optimize_images.py takes folders on the command line, not env, e.g.:
#   python scripts/optimize_images.py --src ./raw-photos --out ./assets/devices
# There is no Directus storage secret here: uploads are managed by Directus
# itself (the ./uploads volume in infra/directus-beget).
