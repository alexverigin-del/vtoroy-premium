# Copy to `.env` and fill in real values. NEVER commit `.env`.
#   cp .env.example .env

# Directus connection for import/export jobs.
DIRECTUS_URL=https://api.your-domain.ru
# Static token for an Editor-role service account (NOT the admin token).
DIRECTUS_TOKEN=replace-with-service-account-token

# Telegram notifications.
TELEGRAM_BOT_TOKEN=replace-with-botfather-token
TELEGRAM_CHAT_ID=replace-with-chat-id
